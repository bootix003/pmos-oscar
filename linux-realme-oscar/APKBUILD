pkgname="linux-realme-oscar"
pkgver=5.4.292
pkgrel=0
pkgdesc="Realme 9 Pro 5G downstream kernel (SM6375)"
arch="aarch64"
license="GPL-2.0-only"
url="https://github.com/frpunlocking-com/android_kernel_realme_sm6375"
options="!strip !check !tracedeps pmb:kconfigcheck-nftables"
makedepends="
	bash bc bison devicepkg-dev elfutils-dev flex
	gcc gmp-dev installkernel
	linux-headers openssl-dev perl python3 sed
"
_carch="arm64"
_flavor="realme-oscar"
_config="config-$_flavor.$_carch"
_repo="frpunlocking-com/android_kernel_realme_sm6375"
_branch="main"

source="
	linux-$pkgver-$_flavor.tar.gz::https://github.com/$_repo/archive/refs/heads/$_branch.tar.gz
	$_config
"
builddir="$srcdir/android_kernel_realme_sm6375-$_branch"

prepare() {
	default_prepare
	cp "$srcdir/$_config" .config
	make ARCH="$_carch" olddefconfig
}

build() {
	unset LDFLAGS
	make ARCH="$_carch" \
		CC="${CC:-gcc}" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1))-postmarketOS" \
		Image.gz modules
}

package() {
	install -Dm644 arch/arm64/boot/Image.gz \
		"$pkgdir/boot/vmlinuz"
	make ARCH="$_carch" \
		INSTALL_MOD_PATH="$pkgdir" \
		modules_install
	install -Dm644 include/config/kernel.release \
		"$pkgdir/usr/share/kernel/$_flavor/kernel.release"
}
